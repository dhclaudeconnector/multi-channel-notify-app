# ======================================================================
# MULTI ENV NOTIFY CLI - .env.example
# ======================================================================
# Mục tiêu:
# - Kênh nào đủ cấu hình thì gửi.
# - Kênh nào thiếu cấu hình thì tự bỏ qua.
# - Tất cả channel đều hỗ trợ multi env.
#
# Quy tắc đặt biến khuyến nghị:
#
# 1) Cấu hình mặc định:
#    MULTI_NOTIFY_TELEGRAM_BOT_TOKEN=
#    MULTI_NOTIFY_TELEGRAM_CHAT_ID=
#
# 2) Cấu hình nhiều target dạng suffix:
#    MULTI_NOTIFY_SLACK_WEBHOOK_URL_1=
#    MULTI_NOTIFY_SLACK_WEBHOOK_URL_2=
#
# 3) Cấu hình nhiều target dạng prefix:
#    MULTI_NOTIFY_SLACK_1_WEBHOOK_URL=
#    MULTI_NOTIFY_SLACK_2_WEBHOOK_URL=
#
# 4) Với provider có nhiều trường cấu hình:
#    MULTI_NOTIFY_SMTP_1_HOST=
#    MULTI_NOTIFY_SMTP_1_PORT=
#    MULTI_NOTIFY_SMTP_1_USER=
#    MULTI_NOTIFY_SMTP_1_PASS=
#
# Khuyến nghị:
# - Khi public repo lên GitHub/NPM: KHÔNG commit file .env thật.
# - Chỉ commit .env.example.
# - Token/API key nếu lộ phải rotate ngay.
# ======================================================================


# ======================================================================
# 0. APP CONFIG
# ======================================================================

# Tên ứng dụng hiển thị trong nội dung thông báo.
# Mặc định khuyến nghị: Multi Env Notify
MULTI_MULTI_NOTIFY_NOTIFY_APP_NAME="Multi Env Notify"

# Level mặc định nếu CLI không truyền --level.
# Tùy chọn hợp lệ:
# - debug
# - info
# - success
# - warning
# - error
MULTI_MULTI_NOTIFY_NOTIFY_DEFAULT_LEVEL=info

# Tiêu đề mặc định nếu CLI không truyền --title.
MULTI_NOTIFY_NOTIFY_TITLE="Thông báo hệ thống"

# Nội dung mặc định nếu CLI không truyền --message.
MULTI_NOTIFY_NOTIFY_MESSAGE="Đây là tin nhắn thử nghiệm từ Multi Env Notify CLI."


# ======================================================================
# 1. TELEGRAM
# ======================================================================
# Hỗ trợ:
# - 1 bot gửi 1 group/chat
# - 1 bot gửi nhiều group/chat
# - nhiều bot, mỗi bot gửi nhiều group/chat
# - group có topic/forum thông qua message_thread_id
#
# Cách lấy MULTI_NOTIFY_TELEGRAM_BOT_TOKEN:
# 1. Mở Telegram, tìm @BotFather
# 2. Gõ /newbot
# 3. Đặt tên bot
# 4. Đặt username bot, bắt buộc kết thúc bằng "bot"
# 5. BotFather trả về token dạng:
#    123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Cách lấy MULTI_NOTIFY_TELEGRAM_CHAT_ID:
# 1. Thêm bot vào group hoặc mở chat riêng với bot
# 2. Nhắn /start hoặc một tin nhắn bất kỳ
# 3. Mở trình duyệt:
#    https://api.telegram.org/bot<MULTI_NOTIFY_TELEGRAM_BOT_TOKEN>/getUpdates
# 4. Tìm:
#    message.chat.id
#
# Ghi chú:
# - Private chat id thường là số dương.
# - Group/supergroup id thường là số âm, ví dụ -1001234567890.
# - Nếu group bật topic/forum, cần thêm THREAD_ID.
# - THREAD_ID chính là message_thread_id của topic cần gửi.
# ======================================================================


# ----------------------------------------------------------------------
# 1.1. Telegram - cấu hình mặc định: 1 bot gửi 1 chat/group
# ----------------------------------------------------------------------
# Bật khi đủ:
# - MULTI_NOTIFY_TELEGRAM_BOT_TOKEN
# - MULTI_NOTIFY_TELEGRAM_CHAT_ID

MULTI_NOTIFY_TELEGRAM_BOT_TOKEN=
MULTI_NOTIFY_TELEGRAM_BOT_NAME=default-bot
MULTI_NOTIFY_TELEGRAM_CHAT_ID=
MULTI_NOTIFY_TELEGRAM_CHAT_NAME=default-chat

# Tùy chọn:
# - HTML: hỗ trợ <b>, <i>, <code>...
# - MarkdownV2: cần escape ký tự đặc biệt, dễ lỗi hơn
# - để trống: gửi plain text
MULTI_NOTIFY_TELEGRAM_PARSE_MODE=HTML

# Tùy chọn nếu gửi vào topic/forum.
# Có thể dùng một trong các biến dưới.
MULTI_NOTIFY_TELEGRAM_MESSAGE_THREAD_ID=
MULTI_NOTIFY_TELEGRAM_THREAD_ID=
MULTI_NOTIFY_TELEGRAM_CHAT_ID_THREAD_ID=


# ----------------------------------------------------------------------
# 1.2. Telegram - 1 bot gửi nhiều group/chat
# ----------------------------------------------------------------------
# Dùng chung MULTI_NOTIFY_TELEGRAM_BOT_TOKEN ở trên.
# Bật target nào thì điền target đó.
#
# Quy tắc:
# MULTI_NOTIFY_TELEGRAM_CHAT_ID_<NO>=
# MULTI_NOTIFY_TELEGRAM_CHAT_ID_<NO>_NAME=
# MULTI_NOTIFY_TELEGRAM_CHAT_ID_<NO>_THREAD_ID=

MULTI_NOTIFY_TELEGRAM_CHAT_ID_1=
MULTI_NOTIFY_TELEGRAM_CHAT_ID_1_NAME=ops-group
MULTI_NOTIFY_TELEGRAM_CHAT_ID_1_THREAD_ID=

MULTI_NOTIFY_TELEGRAM_CHAT_ID_2=
MULTI_NOTIFY_TELEGRAM_CHAT_ID_2_NAME=dev-group
MULTI_NOTIFY_TELEGRAM_CHAT_ID_2_THREAD_ID=

MULTI_NOTIFY_TELEGRAM_CHAT_ID_3=
MULTI_NOTIFY_TELEGRAM_CHAT_ID_3_NAME=business-group
MULTI_NOTIFY_TELEGRAM_CHAT_ID_3_THREAD_ID=


# Dạng danh sách nhanh, phân tách bằng dấu phẩy.
# Phù hợp khi không cần đặt tên từng group.
# Ví dụ:
# MULTI_NOTIFY_TELEGRAM_CHAT_IDS=-1001111111111,-1002222222222,3904019238
MULTI_NOTIFY_TELEGRAM_CHAT_IDS=


# ----------------------------------------------------------------------
# 1.3. Telegram - nhiều bot, mỗi bot gửi nhiều group/chat
# ----------------------------------------------------------------------
# Quy tắc khuyến nghị:
# MULTI_NOTIFY_TELEGRAM_BOT_<BOT_NO>_NAME=
# MULTI_NOTIFY_TELEGRAM_BOT_<BOT_NO>_TOKEN=
# MULTI_NOTIFY_TELEGRAM_BOT_<BOT_NO>_PARSE_MODE=
# MULTI_NOTIFY_TELEGRAM_BOT_<BOT_NO>_CHAT_ID_<CHAT_NO>=
# MULTI_NOTIFY_TELEGRAM_BOT_<BOT_NO>_CHAT_ID_<CHAT_NO>_NAME=
# MULTI_NOTIFY_TELEGRAM_BOT_<BOT_NO>_CHAT_ID_<CHAT_NO>_THREAD_ID=


# Bot 1: ví dụ bot cảnh báo kỹ thuật / vận hành
MULTI_NOTIFY_TELEGRAM_BOT_1_NAME=ops-bot
MULTI_NOTIFY_TELEGRAM_BOT_1_TOKEN=
MULTI_NOTIFY_TELEGRAM_BOT_1_PARSE_MODE=HTML

MULTI_NOTIFY_TELEGRAM_BOT_1_CHAT_ID_1=
MULTI_NOTIFY_TELEGRAM_BOT_1_CHAT_ID_1_NAME=ops-alerts
MULTI_NOTIFY_TELEGRAM_BOT_1_CHAT_ID_1_THREAD_ID=

MULTI_NOTIFY_TELEGRAM_BOT_1_CHAT_ID_2=
MULTI_NOTIFY_TELEGRAM_BOT_1_CHAT_ID_2_NAME=dev-alerts
MULTI_NOTIFY_TELEGRAM_BOT_1_CHAT_ID_2_THREAD_ID=

# Dạng danh sách nhanh cho Bot 1.
# Ví dụ:
# MULTI_NOTIFY_TELEGRAM_BOT_1_CHAT_IDS=-1001111111111,-1002222222222
MULTI_NOTIFY_TELEGRAM_BOT_1_CHAT_IDS=


# Bot 2: ví dụ bot thông báo kinh doanh
MULTI_NOTIFY_TELEGRAM_BOT_2_NAME=business-bot
MULTI_NOTIFY_TELEGRAM_BOT_2_TOKEN=
MULTI_NOTIFY_TELEGRAM_BOT_2_PARSE_MODE=HTML

MULTI_NOTIFY_TELEGRAM_BOT_2_CHAT_ID_1=
MULTI_NOTIFY_TELEGRAM_BOT_2_CHAT_ID_1_NAME=sales-group
MULTI_NOTIFY_TELEGRAM_BOT_2_CHAT_ID_1_THREAD_ID=

MULTI_NOTIFY_TELEGRAM_BOT_2_CHAT_ID_2=
MULTI_NOTIFY_TELEGRAM_BOT_2_CHAT_ID_2_NAME=admin-group
MULTI_NOTIFY_TELEGRAM_BOT_2_CHAT_ID_2_THREAD_ID=

MULTI_NOTIFY_TELEGRAM_BOT_2_CHAT_IDS=


# Bot 3: để sẵn nếu cần mở rộng
MULTI_NOTIFY_TELEGRAM_BOT_3_NAME=extra-bot
MULTI_NOTIFY_TELEGRAM_BOT_3_TOKEN=
MULTI_NOTIFY_TELEGRAM_BOT_3_PARSE_MODE=HTML

MULTI_NOTIFY_TELEGRAM_BOT_3_CHAT_ID_1=
MULTI_NOTIFY_TELEGRAM_BOT_3_CHAT_ID_1_NAME=extra-group
MULTI_NOTIFY_TELEGRAM_BOT_3_CHAT_ID_1_THREAD_ID=

MULTI_NOTIFY_TELEGRAM_BOT_3_CHAT_IDS=


# ======================================================================
# 2. EMAIL SMTP
# ======================================================================
# Hỗ trợ:
# - 1 tài khoản SMTP gửi tới 1 hoặc nhiều email
# - nhiều tài khoản SMTP khác nhau
#
# MULTI_NOTIFY_EMAIL_TO có thể là:
# - một email:
#   admin@example.com
# - nhiều email, phân tách bằng dấu phẩy:
#   admin@example.com,dev@example.com,ops@example.com
#
# MULTI_NOTIFY_SMTP_SECURE:
# - true  : thường dùng với port 465 SSL
# - false : thường dùng với port 587 STARTTLS
#
# SMTP phổ biến:
#
# Gmail / Google Workspace:
# - MULTI_NOTIFY_SMTP_HOST=smtp.gmail.com
# - MULTI_NOTIFY_SMTP_PORT=587
# - MULTI_NOTIFY_SMTP_SECURE=false
# - MULTI_NOTIFY_SMTP_USER=your@gmail.com
# - MULTI_NOTIFY_SMTP_PASS=App Password, không nên dùng mật khẩu Gmail thường
#
# Gmail SSL:
# - MULTI_NOTIFY_SMTP_HOST=smtp.gmail.com
# - MULTI_NOTIFY_SMTP_PORT=465
# - MULTI_NOTIFY_SMTP_SECURE=true
#
# Outlook / Hotmail / Live:
# - MULTI_NOTIFY_SMTP_HOST=smtp-mail.outlook.com
# - MULTI_NOTIFY_SMTP_PORT=587
# - MULTI_NOTIFY_SMTP_SECURE=false
# - MULTI_NOTIFY_SMTP_USER=your@hotmail.com hoặc your@outlook.com
# - MULTI_NOTIFY_SMTP_PASS=mật khẩu hoặc app password nếu bật 2FA
#
# Microsoft 365 Business:
# - MULTI_NOTIFY_SMTP_HOST=smtp.office365.com
# - MULTI_NOTIFY_SMTP_PORT=587
# - MULTI_NOTIFY_SMTP_SECURE=false
# - MULTI_NOTIFY_SMTP_USER=your@yourdomain.com
#
# Zoho Mail:
# - MULTI_NOTIFY_SMTP_HOST=smtp.zoho.com
# - MULTI_NOTIFY_SMTP_PORT=587
# - MULTI_NOTIFY_SMTP_SECURE=false
# hoặc:
# - MULTI_NOTIFY_SMTP_PORT=465
# - MULTI_NOTIFY_SMTP_SECURE=true
#
# Yahoo Mail:
# - MULTI_NOTIFY_SMTP_HOST=smtp.mail.yahoo.com
# - MULTI_NOTIFY_SMTP_PORT=587
# - MULTI_NOTIFY_SMTP_SECURE=false
# hoặc:
# - MULTI_NOTIFY_SMTP_PORT=465
# - MULTI_NOTIFY_SMTP_SECURE=true
# - thường cần tạo App Password
#
# Yandex Mail:
# - MULTI_NOTIFY_SMTP_HOST=smtp.yandex.com
# - MULTI_NOTIFY_SMTP_PORT=465
# - MULTI_NOTIFY_SMTP_SECURE=true
#
# Mailgun:
# - MULTI_NOTIFY_SMTP_HOST=smtp.mailgun.org
# - MULTI_NOTIFY_SMTP_PORT=587
# - MULTI_NOTIFY_SMTP_SECURE=false
#
# SendGrid:
# - MULTI_NOTIFY_SMTP_HOST=smtp.sendgrid.net
# - MULTI_NOTIFY_SMTP_PORT=587
# - MULTI_NOTIFY_SMTP_SECURE=false
# - MULTI_NOTIFY_SMTP_USER=apikey
# - MULTI_NOTIFY_SMTP_PASS=SendGrid API Key
#
# Amazon SES SMTP:
# - MULTI_NOTIFY_SMTP_HOST=email-smtp.<region>.amazonaws.com
#   Ví dụ: email-smtp.ap-southeast-1.amazonaws.com
# - MULTI_NOTIFY_SMTP_PORT=587
# - MULTI_NOTIFY_SMTP_SECURE=false
# - MULTI_NOTIFY_SMTP_USER=SMTP username do SES cấp
# - MULTI_NOTIFY_SMTP_PASS=SMTP password do SES cấp
#
# Cách lấy thông tin SMTP:
# - Gmail: bật 2-Step Verification, tạo App Password.
# - Outlook/Hotmail: dùng tài khoản Microsoft, có thể cần app password nếu bật 2FA.
# - Zoho: vào Zoho Mail Admin/User Settings để lấy SMTP.
# - SendGrid/Mailgun/SES: vào dashboard provider để tạo SMTP credential.
# ======================================================================


# ----------------------------------------------------------------------
# 2.1. Email SMTP - cấu hình mặc định
# ----------------------------------------------------------------------
# Bật khi đủ:
# - MULTI_NOTIFY_SMTP_HOST
# - MULTI_NOTIFY_SMTP_PORT
# - MULTI_NOTIFY_SMTP_USER
# - MULTI_NOTIFY_SMTP_PASS
# - MULTI_NOTIFY_EMAIL_FROM
# - MULTI_NOTIFY_EMAIL_TO

MULTI_NOTIFY_EMAIL_NAME=default-email
MULTI_NOTIFY_SMTP_HOST=
MULTI_NOTIFY_SMTP_PORT=587
MULTI_NOTIFY_SMTP_SECURE=false
MULTI_NOTIFY_SMTP_USER=
MULTI_NOTIFY_SMTP_PASS=

# Email người gửi.
# Nên trùng hoặc cùng domain với MULTI_NOTIFY_SMTP_USER để tránh bị chặn SPF/DKIM/DMARC.
MULTI_NOTIFY_EMAIL_FROM=

# Email người nhận.
# Có thể nhập nhiều email, phân tách bằng dấu phẩy.
MULTI_NOTIFY_EMAIL_TO=


# ----------------------------------------------------------------------
# 2.2. Email SMTP - multi env dạng prefix, khuyến nghị
# ----------------------------------------------------------------------
# Quy tắc:
# MULTI_NOTIFY_SMTP_<NO>_HOST=
# MULTI_NOTIFY_SMTP_<NO>_PORT=
# MULTI_NOTIFY_SMTP_<NO>_SECURE=
# MULTI_NOTIFY_SMTP_<NO>_USER=
# MULTI_NOTIFY_SMTP_<NO>_PASS=
# MULTI_NOTIFY_EMAIL_<NO>_FROM=
# MULTI_NOTIFY_EMAIL_<NO>_TO=
# MULTI_NOTIFY_EMAIL_<NO>_NAME=


# SMTP 1: ví dụ Gmail
MULTI_NOTIFY_EMAIL_1_NAME=gmail-main
MULTI_NOTIFY_SMTP_1_HOST=smtp.gmail.com
MULTI_NOTIFY_SMTP_1_PORT=587
MULTI_NOTIFY_SMTP_1_SECURE=false
MULTI_NOTIFY_SMTP_1_USER=
MULTI_NOTIFY_SMTP_1_PASS=
MULTI_NOTIFY_EMAIL_1_FROM=
MULTI_NOTIFY_EMAIL_1_TO=


# SMTP 2: ví dụ Outlook/Hotmail
MULTI_NOTIFY_EMAIL_2_NAME=outlook-main
MULTI_NOTIFY_SMTP_2_HOST=smtp-mail.outlook.com
MULTI_NOTIFY_SMTP_2_PORT=587
MULTI_NOTIFY_SMTP_2_SECURE=false
MULTI_NOTIFY_SMTP_2_USER=
MULTI_NOTIFY_SMTP_2_PASS=
MULTI_NOTIFY_EMAIL_2_FROM=
MULTI_NOTIFY_EMAIL_2_TO=


# SMTP 3: ví dụ Zoho
MULTI_NOTIFY_EMAIL_3_NAME=zoho-main
MULTI_NOTIFY_SMTP_3_HOST=smtp.zoho.com
MULTI_NOTIFY_SMTP_3_PORT=587
MULTI_NOTIFY_SMTP_3_SECURE=false
MULTI_NOTIFY_SMTP_3_USER=
MULTI_NOTIFY_SMTP_3_PASS=
MULTI_NOTIFY_EMAIL_3_FROM=
MULTI_NOTIFY_EMAIL_3_TO=


# SMTP 4: ví dụ SendGrid
MULTI_NOTIFY_EMAIL_4_NAME=sendgrid-main
MULTI_NOTIFY_SMTP_4_HOST=smtp.sendgrid.net
MULTI_NOTIFY_SMTP_4_PORT=587
MULTI_NOTIFY_SMTP_4_SECURE=false
MULTI_NOTIFY_SMTP_4_USER=apikey
MULTI_NOTIFY_SMTP_4_PASS=
MULTI_NOTIFY_EMAIL_4_FROM=
MULTI_NOTIFY_EMAIL_4_TO=


# SMTP 5: ví dụ Amazon SES
MULTI_NOTIFY_EMAIL_5_NAME=ses-main
MULTI_NOTIFY_SMTP_5_HOST=email-smtp.ap-southeast-1.amazonaws.com
MULTI_NOTIFY_SMTP_5_PORT=587
MULTI_NOTIFY_SMTP_5_SECURE=false
MULTI_NOTIFY_SMTP_5_USER=
MULTI_NOTIFY_SMTP_5_PASS=
MULTI_NOTIFY_EMAIL_5_FROM=
MULTI_NOTIFY_EMAIL_5_TO=


# ----------------------------------------------------------------------
# 2.3. Email SMTP - multi env dạng suffix, nếu muốn hỗ trợ alias
# ----------------------------------------------------------------------
# Quy tắc:
# MULTI_NOTIFY_SMTP_HOST_<NO>=
# MULTI_NOTIFY_SMTP_PORT_<NO>=
# MULTI_NOTIFY_SMTP_SECURE_<NO>=
# MULTI_NOTIFY_SMTP_USER_<NO>=
# MULTI_NOTIFY_SMTP_PASS_<NO>=
# MULTI_NOTIFY_EMAIL_FROM_<NO>=
# MULTI_NOTIFY_EMAIL_TO_<NO>=
# MULTI_NOTIFY_EMAIL_NAME_<NO>=

MULTI_NOTIFY_EMAIL_NAME_1=gmail-alias
MULTI_NOTIFY_SMTP_HOST_1=smtp.gmail.com
MULTI_NOTIFY_SMTP_PORT_1=587
MULTI_NOTIFY_SMTP_SECURE_1=false
MULTI_NOTIFY_SMTP_USER_1=
MULTI_NOTIFY_SMTP_PASS_1=
MULTI_NOTIFY_EMAIL_FROM_1=
MULTI_NOTIFY_EMAIL_TO_1=

MULTI_NOTIFY_EMAIL_NAME_2=outlook-alias
MULTI_NOTIFY_SMTP_HOST_2=smtp-mail.outlook.com
MULTI_NOTIFY_SMTP_PORT_2=587
MULTI_NOTIFY_SMTP_SECURE_2=false
MULTI_NOTIFY_SMTP_USER_2=
MULTI_NOTIFY_SMTP_PASS_2=
MULTI_NOTIFY_EMAIL_FROM_2=
MULTI_NOTIFY_EMAIL_TO_2=


# ======================================================================
# 3. SLACK INCOMING WEBHOOK
# ======================================================================
# Hỗ trợ:
# - 1 Slack webhook
# - nhiều Slack webhook
#
# Cách lấy MULTI_NOTIFY_SLACK_WEBHOOK_URL:
# 1. Vào https://api.slack.com/apps
# 2. Create New App
# 3. Chọn workspace
# 4. Vào Incoming Webhooks
# 5. Bật Activate Incoming Webhooks
# 6. Chọn Add New Webhook to Workspace
# 7. Chọn channel cần nhận thông báo
# 8. Copy Webhook URL
#
# Webhook URL thường có dạng:
#
# Lưu ý:
# - Webhook URL là secret.
# - Ai có URL này đều có thể gửi tin vào channel tương ứng.
# ======================================================================


# ----------------------------------------------------------------------
# 3.1. Slack - cấu hình mặc định
# ----------------------------------------------------------------------
MULTI_NOTIFY_SLACK_WEBHOOK_NAME=default-slack
MULTI_NOTIFY_SLACK_WEBHOOK_URL=


# ----------------------------------------------------------------------
# 3.2. Slack - multi env dạng suffix
# ----------------------------------------------------------------------
MULTI_NOTIFY_SLACK_WEBHOOK_NAME_1=ops-slack
MULTI_NOTIFY_SLACK_WEBHOOK_URL_1=

MULTI_NOTIFY_SLACK_WEBHOOK_NAME_2=dev-slack
MULTI_NOTIFY_SLACK_WEBHOOK_URL_2=

MULTI_NOTIFY_SLACK_WEBHOOK_NAME_3=business-slack
MULTI_NOTIFY_SLACK_WEBHOOK_URL_3=


# ----------------------------------------------------------------------
# 3.3. Slack - multi env dạng prefix
# ----------------------------------------------------------------------
MULTI_NOTIFY_SLACK_1_NAME=ops-slack-prefix
MULTI_NOTIFY_SLACK_1_WEBHOOK_URL=

MULTI_NOTIFY_SLACK_2_NAME=dev-slack-prefix
MULTI_NOTIFY_SLACK_2_WEBHOOK_URL=

MULTI_NOTIFY_SLACK_3_NAME=business-slack-prefix
MULTI_NOTIFY_SLACK_3_WEBHOOK_URL=


# ======================================================================
# 4. DISCORD WEBHOOK
# ======================================================================
# Hỗ trợ:
# - 1 Discord webhook
# - nhiều Discord webhook
#
# Cách lấy MULTI_NOTIFY_DISCORD_WEBHOOK_URL:
# 1. Mở Discord server
# 2. Chọn channel cần nhận thông báo
# 3. Edit Channel
# 4. Integrations
# 5. Webhooks
# 6. New Webhook hoặc Create Webhook
# 7. Copy Webhook URL
#
# Webhook URL thường có dạng:
# https://discord.com/api/webhooks/<webhook_id>/<webhook_token>
#
# Lưu ý:
# - Webhook URL là secret.
# - Ai có URL này đều có thể gửi tin vào channel tương ứng.
# ======================================================================


# ----------------------------------------------------------------------
# 4.1. Discord - cấu hình mặc định
# ----------------------------------------------------------------------
DISCORD_WEBHOOK_NAME=default-discord
MULTI_NOTIFY_DISCORD_WEBHOOK_URL=


# ----------------------------------------------------------------------
# 4.2. Discord - multi env dạng suffix
# ----------------------------------------------------------------------
DISCORD_WEBHOOK_NAME_1=ops-discord
MULTI_NOTIFY_DISCORD_WEBHOOK_URL_1=

DISCORD_WEBHOOK_NAME_2=dev-discord
MULTI_NOTIFY_DISCORD_WEBHOOK_URL_2=

DISCORD_WEBHOOK_NAME_3=business-discord
MULTI_NOTIFY_DISCORD_WEBHOOK_URL_3=


# ----------------------------------------------------------------------
# 4.3. Discord - multi env dạng prefix
# ----------------------------------------------------------------------
DISCORD_1_NAME=ops-discord-prefix
DISCORD_1_WEBHOOK_URL=

DISCORD_2_NAME=dev-discord-prefix
DISCORD_2_WEBHOOK_URL=

DISCORD_3_NAME=business-discord-prefix
DISCORD_3_WEBHOOK_URL=


# ======================================================================
# 5. TWILIO SMS
# ======================================================================
# Hỗ trợ:
# - 1 cấu hình SMS
# - nhiều cấu hình SMS
#
# Cách lấy MULTI_NOTIFY_TWILIO_ACCOUNT_SID và MULTI_NOTIFY_TWILIO_AUTH_TOKEN:
# 1. Đăng nhập Twilio Console
# 2. Vào Account Dashboard
# 3. Copy Account SID
# 4. Copy Auth Token
#
# Cách lấy MULTI_NOTIFY_TWILIO_FROM_NUMBER:
# 1. Vào Phone Numbers / Manage / Active numbers
# 2. Copy số điện thoại Twilio đã mua hoặc được cấp
#
# Cách đặt MULTI_NOTIFY_TWILIO_TO_NUMBER:
# - Là số người nhận theo chuẩn quốc tế E.164
# - Ví dụ Việt Nam:
#   +84901234567
#
# Lưu ý:
# - Tài khoản trial thường chỉ gửi được tới số đã verified.
# - SMS có phí.
# - Với production nên cân nhắc dùng API Key thay cho Auth Token nếu code hỗ trợ.
# ======================================================================


# ----------------------------------------------------------------------
# 5.1. Twilio - cấu hình mặc định
# ----------------------------------------------------------------------
MULTI_NOTIFY_TWILIO_NAME=default-twilio
MULTI_NOTIFY_TWILIO_ACCOUNT_SID=
MULTI_NOTIFY_TWILIO_AUTH_TOKEN=
MULTI_NOTIFY_TWILIO_FROM_NUMBER=
MULTI_NOTIFY_TWILIO_TO_NUMBER=


