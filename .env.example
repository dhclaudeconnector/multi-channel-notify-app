# ======================================================================
# 6. NTFY
# ======================================================================
# Hỗ trợ gửi thông báo qua ntfy: https://github.com/binwiederhier/ntfy
# Bật khi đủ MULTI_NOTIFY_NTFY_TOPIC.
# Nếu self-host thì đổi MULTI_NOTIFY_NTFY_SERVER_URL.
# MULTI_NOTIFY_NTFY_TOKEN dùng cho topic/server yêu cầu auth.
# ======================================================================

MULTI_NOTIFY_NTFY_TOPIC=
MULTI_NOTIFY_NTFY_SERVER_URL=https://ntfy.sh
MULTI_NOTIFY_NTFY_TOKEN=
MULTI_NOTIFY_NTFY_PRIORITY=default
MULTI_NOTIFY_NTFY_TAGS=
MULTI_NOTIFY_NTFY_CLICK_URL=


# ======================================================================
# 7. GENERIC WEBHOOK
# ======================================================================
# Hỗ trợ:
# - 1 webhook bất kỳ
# - nhiều webhook bất kỳ
#
# Dùng cho:
# - n8n webhook
# - Make.com webhook
# - Zapier webhook
# - Pipedream webhook
# - server nội bộ
# - API tự viết
# - webhook test như webhook.site
#
# Cách lấy MULTI_NOTIFY_WEBHOOK_URL:
# - n8n: tạo Webhook node, copy Production URL hoặc Test URL.
# - Make.com: tạo Custom Webhook, copy URL.
# - Zapier: tạo Zap với trigger Webhooks by Zapier.
# - Pipedream: tạo HTTP endpoint.
# - Test nhanh: vào https://webhook.site và copy URL.
#
# MULTI_NOTIFY_WEBHOOK_METHOD:
# - POST: khuyến nghị
# - PUT: nếu API đích yêu cầu
# - PATCH: nếu API đích yêu cầu
#
# Payload gửi đi thường gồm:
# {
#   "title": "...",
#   "message": "...",
#   "level": "info",
#   "timestamp": "...",
#   "meta": {}
# }
# ======================================================================


# ----------------------------------------------------------------------
# 6.1. Generic Webhook - cấu hình mặc định
# ----------------------------------------------------------------------
MULTI_NOTIFY_WEBHOOK_NAME=default-webhook
MULTI_NOTIFY_WEBHOOK_URL=
MULTI_NOTIFY_WEBHOOK_METHOD=POST


# ----------------------------------------------------------------------
# 6.2. Generic Webhook - multi env dạng suffix
# ----------------------------------------------------------------------
MULTI_NOTIFY_WEBHOOK_NAME_1=ops-webhook
MULTI_NOTIFY_WEBHOOK_URL_1=
MULTI_NOTIFY_WEBHOOK_METHOD_1=POST

MULTI_NOTIFY_WEBHOOK_NAME_2=dev-webhook
MULTI_NOTIFY_WEBHOOK_URL_2=
MULTI_NOTIFY_WEBHOOK_METHOD_2=POST

MULTI_NOTIFY_WEBHOOK_NAME_3=business-webhook
MULTI_NOTIFY_WEBHOOK_URL_3=
MULTI_NOTIFY_WEBHOOK_METHOD_3=POST


# ----------------------------------------------------------------------
# 6.3. Generic Webhook - multi env dạng prefix
# ----------------------------------------------------------------------
MULTI_NOTIFY_WEBHOOK_1_NAME=ops-webhook-prefix
MULTI_NOTIFY_WEBHOOK_1_URL=
MULTI_NOTIFY_WEBHOOK_1_METHOD=POST

MULTI_NOTIFY_WEBHOOK_2_NAME=dev-webhook-prefix
MULTI_NOTIFY_WEBHOOK_2_URL=
MULTI_NOTIFY_WEBHOOK_2_METHOD=POST

MULTI_NOTIFY_WEBHOOK_3_NAME=business-webhook-prefix
MULTI_NOTIFY_WEBHOOK_3_URL=
MULTI_NOTIFY_WEBHOOK_3_METHOD=POST


# ======================================================================
# 8. GLOBAL FILTER / CLI RUNTIME OPTIONS
# ======================================================================
# Các biến này là tùy chọn, dùng nếu CLI có hỗ trợ đọc từ env.
# Nếu không dùng thì để trống.
# ======================================================================

# Chỉ gửi một số provider.
# Ví dụ:
# MULTI_NOTIFY_NOTIFY_ONLY=telegram
# MULTI_NOTIFY_NOTIFY_ONLY=telegram,slack,email
MULTI_NOTIFY_NOTIFY_ONLY=

# Chạy thử, không gửi thật.
# Tùy chọn:
# - true
# - false
MULTI_NOTIFY_NOTIFY_DRY_RUN=false

# In kết quả dạng JSON.
# Tùy chọn:
# - true
# - false
MULTI_NOTIFY_NOTIFY_JSON=false

# Timeout mỗi request, đơn vị milliseconds.
# Ví dụ:
# MULTI_NOTIFY_NOTIFY_TIMEOUT_MS=15000
MULTI_NOTIFY_NOTIFY_TIMEOUT_MS=15000

# Nếu muốn dừng ngay khi một kênh lỗi.
# Mặc định nên false để kênh lỗi không ảnh hưởng kênh khác.
MULTI_NOTIFY_NOTIFY_FAIL_FAST=false


# ======================================================================
# 9. VÍ DỤ CẤU HÌNH NHANH
# ======================================================================

